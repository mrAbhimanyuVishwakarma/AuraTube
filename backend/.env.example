# Backend environment variables
# Copy this file to .env and fill in values for local development
# On Render, set these in the Dashboard under Project Settings > Environment Variables

# The URL of your deployed frontend (required for CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# The URL of this backend service (used for OAuth redirects)
BACKEND_URL=http://localhost:8000

# Google OAuth Credentials (for Drive upload feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
